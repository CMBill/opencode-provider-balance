{
  "name": "opencode-provider-balance",
  "version": "0.1.1",
  "description": "OpenCode TUI plugin displaying DeepSeek account balance in the sidebar",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "balance",
    "tui",
    "sidebar"
  ],
  "license": "MIT",
  "author": "CMBill",
  "repository": {
    "type": "git",
    "url": "https://github.com/CMBill/opencode-provider-balance.git"
  },
  "homepage": "https://github.com/CMBill/opencode-provider-balance",
  "bugs": {
    "url": "https://github.com/CMBill/opencode-provider-balance/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./src/index.tsx",
      "config": {
        "enabled": true
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepack": "tsc",
    "version": "tsc"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0",
    "@opencode-ai/sdk": ">=1.14.0",
    "@opentui/core": ">=0.2.0",
    "@opentui/solid": ">=0.2.0",
    "solid-js": ">=1.9.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.50",
    "@opencode-ai/sdk": "^1.14.50",
    "@types/node": "^25.9.1",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.0.0"
}
